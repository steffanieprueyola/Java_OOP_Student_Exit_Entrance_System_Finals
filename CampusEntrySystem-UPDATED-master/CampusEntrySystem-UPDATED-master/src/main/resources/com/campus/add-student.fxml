<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campus.AddStudentController"
            maxWidth="Infinity"
            maxHeight="Infinity"
            stylesheets="@add-student.css"
            style="-fx-background-color: #f5f5f5;">

    <!-- ================= HEADER ================= -->
    <top>

        <AnchorPane prefHeight="75"
                    style="
                        -fx-background-color: linear-gradient(to right, #8B0000, #a00000);
                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 10, 0.2, 0, 2);
                    ">

            <children>

                <!-- BACK BUTTON -->
                <StackPane layoutX="20"
                           layoutY="18"
                           prefWidth="36"
                           prefHeight="36"
                           onMouseClicked="#goBack"
                           styleClass="backButton">

                    <Circle radius="18"
                            fill="#9d1111"/>

                    <Label text="←"
                           style="
                               -fx-font-size: 18px;
                               -fx-font-weight: bold;
                               -fx-text-fill: white;
                           "/>

                </StackPane>

                <!-- TITLE -->
                <VBox layoutX="65"
                      layoutY="5"
                      spacing="2">

                    <Label text="Add New Student"
                           style="
                               -fx-font-size: 28px;
                               -fx-font-weight: bold;
                               -fx-text-fill: white;
                           "/>

                    <Label text="Register a new student into the system"
                           style="
                               -fx-font-size: 13px;
                               -fx-text-fill: #ffe5e5;
                           "/>

                </VBox>

            </children>

        </AnchorPane>

    </top>

    <!-- ================= CENTER CONTENT ================= -->
    <center>

        <StackPane style="-fx-background-color: #f5f5f5;">

            <VBox alignment="CENTER"
                  spacing="12"
                  prefWidth="Infinity"
                  prefHeight="Infinity">

                <padding>
                    <Insets top="12"
                            right="12"
                            bottom="12"
                            left="12"/>
                </padding>

                <!-- FORM CARD -->
                <VBox alignment="TOP_CENTER"
                      spacing="14"
                      prefWidth="700"
                      maxWidth="700"
                      styleClass="mainCard"
                      style="
                          -fx-background-color: white;
                          -fx-background-radius: 24;
                          -fx-border-radius: 24;
                          -fx-border-color: #e5e7eb;
                          -fx-border-width: 1;
                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 18, 0.2, 0, 5);
                      ">

                    <padding>
                        <Insets top="24"
                                right="30"
                                bottom="24"
                                left="30"/>
                    </padding>

                    <!-- ICON -->
                    <StackPane prefWidth="72"
                               prefHeight="72"
                               style="
                                   -fx-background-color: #8B0000;
                                   -fx-background-radius: 18;
                               ">

                        <Label text="🎓"
                               style="
                                   -fx-font-size: 32px;
                                   -fx-text-fill: #ffd700;
                               "/>

                    </StackPane>

                    <!-- TITLE -->
                    <VBox alignment="CENTER"
                          spacing="2">

                        <Label text="Student Registration Form"
                               style="
                                   -fx-font-size: 28px;
                                   -fx-font-weight: bold;
                                   -fx-text-fill: #0f172a;
                               "/>

                        <Label text="Fill in the student details below"
                               style="
                                   -fx-font-size: 14px;
                                   -fx-text-fill: #64748b;
                               "/>

                    </VBox>

                    <Separator prefWidth="600"/>

                    <!-- FULL NAME -->
                    <VBox spacing="6"
                          prefWidth="600">

                        <Label text="Full Name *"
                               styleClass="fieldLabel"/>

                        <TextField fx:id="nameField"
                                   promptText="Enter full name"
                                   prefHeight="42"
                                   styleClass="modernField"/>

                    </VBox>

                    <!-- STUDENT ID -->
                    <VBox spacing="6"
                          prefWidth="600">

                        <Label text="Student ID *"
                               styleClass="fieldLabel"/>

                        <TextField fx:id="studentIdField"
                                   promptText="e.g 2024-0001"
                                   prefHeight="42"
                                   styleClass="modernField"/>

                    </VBox>

                    <!-- COURSE & YEAR -->
                    <HBox spacing="14"
                          prefWidth="600">

                        <!-- COURSE -->
                        <VBox spacing="6"
                              HBox.hgrow="ALWAYS">

                            <Label text="Course *"
                                   styleClass="fieldLabel"/>

                            <TextField fx:id="courseField"
                                       promptText="e.g BSIT"
                                       prefHeight="42"
                                       styleClass="modernField"/>

                        </VBox>

                        <!-- YEAR LEVEL -->
                        <VBox spacing="6"
                              HBox.hgrow="ALWAYS">

                            <Label text="Year Level *"
                                   styleClass="fieldLabel"/>

                            <TextField fx:id="yearLevelField"
                                       promptText="e.g 3rd Year"
                                       prefHeight="42"
                                       styleClass="modernField"/>

                        </VBox>

                    </HBox>

                    <!-- CONTACT -->
                    <VBox spacing="6"
                          prefWidth="600">

                        <Label text="Contact Number *"
                               styleClass="fieldLabel"/>

                        <TextField fx:id="contactField"
                                   promptText="09XXXXXXXXX"
                                   prefHeight="42"
                                   styleClass="modernField"/>

                    </VBox>

                    <!-- EMAIL -->
                    <VBox spacing="6"
                          prefWidth="600">

                        <Label text="Email Address *"
                               styleClass="fieldLabel"/>

                        <TextField fx:id="emailField"
                                   promptText="student@email.com"
                                   prefHeight="42"
                                   styleClass="modernField"/>

                    </VBox>

                    <!-- BUTTONS -->
                    <HBox spacing="12"
                          alignment="CENTER"
                          prefWidth="600">

                        <!-- REGISTER BUTTON -->
                        <Button text="Register Student"
                                onAction="#registerStudent"
                                prefWidth="290"
                                prefHeight="48"
                                styleClass="registerButton"/>

                        <!-- CLEAR BUTTON -->
                        <Button text="Clear Form"
                                onAction="#clearForm"
                                prefWidth="290"
                                prefHeight="48"
                                styleClass="clearButton"/>

                    </HBox>

                </VBox>

            </VBox>

        </StackPane>

    </center>

</BorderPane>
