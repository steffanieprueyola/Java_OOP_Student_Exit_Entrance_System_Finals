<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campus.StudentHistoryController"
            maxWidth="Infinity"
            maxHeight="Infinity"
            stylesheets="@student.css"
            style="-fx-background-color: #f1f1f1;">

    <!-- ================= TOP HEADER ================= -->
    <top>
        <HBox prefHeight="70"
              alignment="CENTER_LEFT"
              spacing="14"
              style="-fx-background-color: #8B0000;
                     -fx-padding: 0 24 0 16;">

            <!-- BACK BUTTON -->
            <StackPane prefWidth="34" prefHeight="34"
                       onMouseClicked="#goBack"
                       style="-fx-cursor: hand;">
                <Circle radius="17" fill="#6e0000"/>
                <Label text="←"
                       style="-fx-font-size: 16px; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </StackPane>

            <!-- HEADER TEXT -->
            <VBox spacing="2">
                <Label text="Student Dashboard"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Campus Entry &amp; Exit Management System"
                       style="-fx-font-size: 12px; -fx-text-fill: #ffcccc;"/>
            </VBox>

        </HBox>
    </top>

    <!-- ================= CENTER ================= -->
    <center>
        <VBox maxWidth="Infinity" maxHeight="Infinity"
              style="-fx-background-color: #f1f1f1;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- CARD WRAPPER -->
            <VBox VBox.vgrow="ALWAYS"
                  maxWidth="Infinity"
                  spacing="0"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12;
                         -fx-border-radius: 12;
                         -fx-border-color: #e2e8f0;
                         -fx-border-width: 1;
                         -fx-effect: dropshadow(gaussian, #00000018, 10, 0.1, 0, 2);">

                <!-- RED TITLE BAR -->
                <VBox style="-fx-background-color: #8B0000;
                             -fx-background-radius: 12 12 0 0;
                             -fx-padding: 14 20 14 20;">
                    <Label text="My Attendance History"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Your personal attendance log"
                           style="-fx-font-size: 12px; -fx-text-fill: #ffcccc;"/>
                </VBox>

                <!-- COLUMN HEADER ROW -->
                <GridPane maxWidth="Infinity"
                          style="-fx-background-color: white;
                                 -fx-border-color: transparent transparent #cccccc transparent;
                                 -fx-border-width: 0 0 1 0;">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="DATE" GridPane.columnIndex="0" maxWidth="Infinity"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #334155;
                                  -fx-padding: 10 14 10 14;
                                  -fx-border-color: transparent #cccccc transparent transparent;
                                  -fx-border-width: 0 1 0 0;"/>
                    <Label text="TIME IN" GridPane.columnIndex="1" maxWidth="Infinity"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #334155;
                                  -fx-padding: 10 14 10 14;
                                  -fx-border-color: transparent #cccccc transparent transparent;
                                  -fx-border-width: 0 1 0 0;"/>
                    <Label text="TIME OUT" GridPane.columnIndex="2" maxWidth="Infinity"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #334155;
                                  -fx-padding: 10 14 10 14;
                                  -fx-border-color: transparent #cccccc transparent transparent;
                                  -fx-border-width: 0 1 0 0;"/>
                    <Label text="STATUS" GridPane.columnIndex="3" maxWidth="Infinity"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #334155;
                                  -fx-padding: 10 14 10 14;"/>
                </GridPane>

                <!-- SCROLLABLE ROWS -->
                <ScrollPane fitToWidth="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            VBox.vgrow="ALWAYS"
                            style="-fx-background: white;
                                   -fx-background-color: white;
                                   -fx-border-color: transparent;">
                    <VBox fx:id="historyRowsContainer" maxWidth="Infinity" spacing="0"/>
                </ScrollPane>

                <!-- SUMMARY ROW -->
                <HBox maxWidth="Infinity" alignment="CENTER_RIGHT"
                      style="-fx-padding: 8 16 8 16;
                             -fx-background-color: white;
                             -fx-background-radius: 0 0 12 12;
                             -fx-border-color: #e2e8f0 transparent transparent transparent;
                             -fx-border-width: 1 0 0 0;">
                    <Label fx:id="summaryLabel" text=""
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                </HBox>

            </VBox>
        </VBox>
    </center>

</BorderPane>
