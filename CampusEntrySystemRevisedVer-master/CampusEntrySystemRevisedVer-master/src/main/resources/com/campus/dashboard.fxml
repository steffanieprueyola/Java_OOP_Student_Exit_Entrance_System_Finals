<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campus.DashboardController"
            maxWidth="Infinity"
            maxHeight="Infinity"
            stylesheets="@dashboard.css"
            style="-fx-background-color: #f5f5f5;">

    <!-- ================= HEADER ================= -->
    <top>

        <AnchorPane prefHeight="75"
                    style="
                        -fx-background-color: linear-gradient(to right, #8B0000, #a00000);
                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 10, 0.2, 0, 2);
                    ">

            <children>

                <!-- TITLE -->
                <VBox layoutX="24"
                      layoutY="10"
                      spacing="2">

                    <Label text="Administrator Dashboard"
                           style="
                               -fx-font-size: 30px;
                               -fx-font-weight: bold;
                               -fx-text-fill: white;
                           "/>

                    <Label text="Campus Entry &amp; Exit Management System"
                           style="
                               -fx-font-size: 12px;
                               -fx-text-fill: #ffe5e5;
                           "/>

                </VBox>

                <!-- ADMIN BADGE -->
                <StackPane prefWidth="140"
                           prefHeight="34"
                           AnchorPane.rightAnchor="18"
                           AnchorPane.topAnchor="18"
                           style="
                               -fx-background-color: rgba(255,255,255,0.12);
                               -fx-background-radius: 10;
                               -fx-border-color: rgba(255,255,255,0.25);
                               -fx-border-radius: 10;
                           ">

                    <Label text="ADMIN PANEL"
                           style="
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-text-fill: white;
                           "/>

                </StackPane>

            </children>

        </AnchorPane>

    </top>

    <!-- ================= MAIN CONTENT ================= -->
    <center>

        <VBox spacing="16"
              style="-fx-padding: 16;">

            <!-- ================= STATS CARDS ================= -->
            <HBox spacing="14"
                  alignment="CENTER">

                <!-- TOTAL ENTRIES -->
                <VBox prefWidth="290"
                      prefHeight="105"
                      spacing="8"
                      styleClass="statCard">

                    <HBox alignment="TOP_LEFT">

                        <StackPane prefWidth="42"
                                   prefHeight="42"
                                   style="
                                       -fx-background-color: #8B0000;
                                       -fx-background-radius: 12;
                                   ">

                            <Label text="👥"
                                   style="
                                       -fx-font-size: 18px;
                                       -fx-text-fill: #ffd700;
                                   "/>

                        </StackPane>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label fx:id="totalEntriesLabel"
                               text="8"
                               style="
                                   -fx-font-size: 28px;
                                   -fx-text-fill: #0f172a;
                               "/>

                    </HBox>

                    <Label text="TOTAL ENTRIES"
                           styleClass="statTitle"/>

                    <Label text="↗ Active today"
                           styleClass="greenText"/>

                </VBox>

                <!-- TIME IN -->
                <VBox prefWidth="290"
                      prefHeight="105"
                      spacing="8"
                      styleClass="statCard">

                    <HBox alignment="TOP_LEFT">

                        <StackPane prefWidth="42"
                                   prefHeight="42"
                                   style="
                                       -fx-background-color: #d4a514;
                                       -fx-background-radius: 12;
                                   ">

                            <Label text="➜"
                                   style="
                                       -fx-font-size: 18px;
                                       -fx-text-fill: white;
                                   "/>

                        </StackPane>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label fx:id="timeInLabel"
                               text="8"
                               style="
                                   -fx-font-size: 28px;
                                   -fx-text-fill: #0f172a;
                               "/>

                    </HBox>

                    <Label text="TOTAL TIME-INS"
                           styleClass="statTitle"/>

                    <Label text="◷ Today's check-ins"
                           styleClass="mutedText"/>

                </VBox>

                <!-- TIME OUT -->
                <VBox prefWidth="290"
                      prefHeight="105"
                      spacing="8"
                      styleClass="statCard">

                    <HBox alignment="TOP_LEFT">

                        <StackPane prefWidth="42"
                                   prefHeight="42"
                                   style="
                                       -fx-background-color: #d4a514;
                                       -fx-background-radius: 12;
                                   ">

                            <Label text="⬅"
                                   style="
                                       -fx-font-size: 18px;
                                       -fx-text-fill: white;
                                   "/>

                        </StackPane>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label fx:id="timeOutLabel"
                               text="3"
                               style="
                                   -fx-font-size: 28px;
                                   -fx-text-fill: #0f172a;
                               "/>

                    </HBox>

                    <Label text="TOTAL TIME-OUTS"
                           styleClass="statTitle"/>

                    <Label text="◷ Today's check-outs"
                           styleClass="mutedText"/>

                </VBox>

                <!-- CURRENT -->
                <VBox prefWidth="290"
                      prefHeight="105"
                      spacing="8"
                      styleClass="statCard">

                    <HBox alignment="TOP_LEFT">

                        <StackPane prefWidth="42"
                                   prefHeight="42"
                                   style="
                                       -fx-background-color: #16a34a;
                                       -fx-background-radius: 12;
                                   ">

                            <Label text="👥"
                                   style="
                                       -fx-font-size: 18px;
                                       -fx-text-fill: white;
                                   "/>

                        </StackPane>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label fx:id="currentlyInLabel"
                               text="0"
                               style="
                                   -fx-font-size: 28px;
                                   -fx-text-fill: #0f172a;
                               "/>

                    </HBox>

                    <Label text="CURRENTLY IN CAMPUS"
                           styleClass="statTitle"/>

                    <Label text="● Live count"
                           styleClass="greenText"/>

                </VBox>

                <!-- CURRENTLY IN — MALE -->
                <VBox prefWidth="200"
                      prefHeight="105"
                      spacing="8"
                      styleClass="statCard">

                    <HBox alignment="TOP_LEFT">

                        <StackPane prefWidth="42"
                                   prefHeight="42"
                                   style="
                                       -fx-background-color: #2563eb;
                                       -fx-background-radius: 12;
                                   ">

                            <Label text="♂"
                                   style="
                                       -fx-font-size: 18px;
                                       -fx-text-fill: white;
                                   "/>

                        </StackPane>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label fx:id="currentlyInMaleLabel"
                               text="0"
                               style="
                                   -fx-font-size: 28px;
                                   -fx-text-fill: #0f172a;
                               "/>

                    </HBox>

                    <Label text="MALE IN CAMPUS"
                           styleClass="statTitle"/>

                    <Label text="● Live count"
                           styleClass="greenText"/>

                </VBox>

                <!-- CURRENTLY IN — FEMALE -->
                <VBox prefWidth="200"
                      prefHeight="105"
                      spacing="8"
                      styleClass="statCard">

                    <HBox alignment="TOP_LEFT">

                        <StackPane prefWidth="42"
                                   prefHeight="42"
                                   style="
                                       -fx-background-color: #db2777;
                                       -fx-background-radius: 12;
                                   ">

                            <Label text="♀"
                                   style="
                                       -fx-font-size: 18px;
                                       -fx-text-fill: white;
                                   "/>

                        </StackPane>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label fx:id="currentlyInFemaleLabel"
                               text="0"
                               style="
                                   -fx-font-size: 28px;
                                   -fx-text-fill: #0f172a;
                               "/>

                    </HBox>

                    <Label text="FEMALE IN CAMPUS"
                           styleClass="statTitle"/>

                    <Label text="● Live count"
                           styleClass="greenText"/>

                </VBox>

            </HBox>

            <!-- ================= TABLE CARD ================= -->
            <VBox spacing="0"
                  VBox.vgrow="ALWAYS"
                  style="
                      -fx-background-color: white;
                      -fx-background-radius: 18;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 18, 0.2, 0, 4);
                  ">

                <!-- TABLE HEADER -->
                <VBox spacing="4"
                      style="
                          -fx-background-color: linear-gradient(to right, #8B0000, #a00000);
                          -fx-background-radius: 18 18 0 0;
                          -fx-padding: 14 18 14 18;
                      ">

                    <Label text="Student Entry Records"
                           style="
                               -fx-font-size: 20px;
                               -fx-font-weight: bold;
                               -fx-text-fill: white;
                           "/>

                    <Label text="Attendance log — select a row, then use the action button below to delete"
                           style="
                               -fx-font-size: 12px;
                               -fx-text-fill: #ffe5e5;
                           "/>

                </VBox>

                <!-- SEX FILTER BAR -->
                <HBox alignment="CENTER_LEFT"
                      spacing="10"
                      style="-fx-padding: 10 18 10 18; -fx-background-color: #fafafa;">

                    <Label text="Filter currently-in by sex:"
                           style="
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-text-fill: #475569;
                           "/>

                    <ComboBox fx:id="sexFilterComboBox"
                              prefWidth="160"
                              prefHeight="34"/>

                </HBox>

                <!-- TABLE -->
                <TableView fx:id="entryTableView"
                           VBox.vgrow="ALWAYS"
                           maxWidth="Infinity"
                           maxHeight="Infinity"
                           styleClass="modernTable">

                    <columns>

                        <TableColumn fx:id="colStudentNumber"
                                     text="STUDENT ID"
                                     prefWidth="170"/>

                        <TableColumn fx:id="colStudentName"
                                     text="NAME"
                                     prefWidth="210"/>

                        <TableColumn fx:id="colSex"
                                     text="SEX"
                                     prefWidth="70"/>

                        <TableColumn fx:id="colStatus"
                                     text="STATUS"
                                     prefWidth="130"/>

                        <TableColumn fx:id="colTimeIn"
                                     text="TIME IN"
                                     prefWidth="140"/>

                        <TableColumn fx:id="colTimeOut"
                                     text="TIME OUT"
                                     prefWidth="140"/>

                        <TableColumn fx:id="colDate"
                                     text="DATE"
                                     prefWidth="140"/>

                    </columns>

                </TableView>

            </VBox>

            <!-- ================= ACTION BUTTONS ================= -->
            <HBox alignment="CENTER_LEFT"
                  spacing="12">

                <Button text="👥 Add New Student"
                        onAction="#addStudent"
                        prefHeight="42"
                        styleClass="primaryButton"/>

                <Button text="📋 View Registered Students"
                        onAction="#viewRegisteredStudents"
                        prefHeight="42"
                        styleClass="viewStudentsButton"/>

                <!-- CRUD ACTION BUTTONS (operate on selected row) -->
                <Button fx:id="deleteButton"
                        text="🗑 Delete Selected"
                        onAction="#handleDeleteSelected"
                        prefHeight="42"
                        disable="true"
                        styleClass="deleteActionButton"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- ================= DATE + GENDER FILTER + EXPORT ================= -->
                <!-- Grouped card so the date picker, gender combo, and export button read as one unit -->
                <HBox spacing="0"
                      alignment="CENTER"
                      style="
                          -fx-background-color: white;
                          -fx-background-radius: 10;
                          -fx-border-color: #d1d5db;
                          -fx-border-radius: 10;
                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 6, 0.1, 0, 2);
                      ">

                    <!-- Date label -->
                    <Label text="📅"
                           style="
                               -fx-font-size: 16px;
                               -fx-padding: 0 4 0 10;
                           "/>

                    <!-- DatePicker -->
                    <DatePicker fx:id="exportDatePicker"
                                prefHeight="42"
                                prefWidth="140"
                                promptText="Pick a date"
                                style="
                                    -fx-background-color: transparent;
                                    -fx-border-color: transparent;
                                    -fx-padding: 0;
                                "/>

                    <!-- Gender combo used for export filtering -->
                    <ComboBox fx:id="exportGenderComboBox"
                              prefHeight="42"
                              prefWidth="110"
                              promptText="Gender"
                              style="
                                  -fx-background-color: transparent;
                                  -fx-border-color: transparent transparent transparent #e5e7eb;
                                  -fx-padding: 0;
                              "/>

                    <!-- Export by Date &amp; Gender button (uses date + gender combo above, gender optional) -->
                    <Button fx:id="exportByDateButton"
                            text="⇩ Export"
                            onAction="#exportCSVByDateAndGender"
                            prefHeight="42"
                            style="
                                -fx-background-color: #8B0000;
                                -fx-background-radius: 0 10 10 0;
                                -fx-text-fill: white;
                                -fx-font-weight: bold;
                                -fx-font-size: 13px;
                                -fx-cursor: hand;
                                -fx-padding: 0 16 0 16;
                            "/>

                </HBox>

                <!-- Standalone Export by Gender button (ignores date, uses exportGenderComboBox selection) -->
                <Button fx:id="exportByGenderButton"
                        text="⇩ Export by Gender"
                        onAction="#exportCSVByGender"
                        prefHeight="42"
                        style="
                            -fx-background-color: #2563eb;
                            -fx-background-radius: 10;
                            -fx-text-fill: white;
                            -fx-font-weight: bold;
                            -fx-font-size: 13px;
                            -fx-cursor: hand;
                            -fx-padding: 0 16 0 16;
                        "/>

                <!-- Today quick-export button -->
                <Button text="⇩ Export Today"
                        onAction="#exportCSV"
                        prefHeight="42"
                        styleClass="exportButton"/>

                <Button text="↪ Logout"
                        onAction="#logout"
                        prefHeight="42"
                        styleClass="logoutButton"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>
